# Repo scripts / Makefile config
# Needed for deploy and Terraform helper commands. These are not secrets.
PROJECT=aventi
ENV=dev
AWS_REGION=us-east-1
RUNTIME_ENV_FILE=services/backend/.env.production

# Secret: only needed when running `make migrate-remote`.
SUPABASE_DB_PASSWORD=

# Secret: optional local utility script DB URLs.
# Some scripts read DATABASE_URL; backend code reads AVENTI_DATABASE_URL.
DATABASE_URL=
AVENTI_DATABASE_URL=
