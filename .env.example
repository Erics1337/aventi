# Repo scripts / Makefile config
# Needed for deploy and Terraform helper commands. These are not secrets.
PROJECT=aventi
ENV=dev
AWS_REGION=us-east-1
RUNTIME_ENV_FILE=services/backend/.env.production

# Secret: direct Postgres URL for repo ops (`psql`, `supabase db push`, reports).
# Use the direct URL, not the backend asyncpg URL and not the Supabase pooler URL.
# Example: postgresql://postgres:PERCENT_ENCODED_PASSWORD@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=

# Secret: backend runtime URL for SQLAlchemy asyncpg.
# Example: postgresql+asyncpg://postgres.<project-ref>:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres
AVENTI_DATABASE_URL=
