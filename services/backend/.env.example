# Backend runtime config: non-secret
AVENTI_ENV=development
AVENTI_BACKEND_HOST=0.0.0.0
AVENTI_BACKEND_PORT=8000
AVENTI_BACKEND_LOG_LEVEL=INFO
AVENTI_SUPABASE_JWT_AUDIENCE=authenticated
AVENTI_FREE_SWIPE_LIMIT=10
AVENTI_FEED_VERIFICATION_MAX_AGE_HOURS=72
AVENTI_FEED_UNVERIFIED_GRACE_HOURS=48
# Local development can use true. Deployed environments should use false.
AVENTI_AUTH_DEV_BYPASS=true
AVENTI_ENABLE_VERIFICATION=true
AVENTI_SEEN_EVENTS_WINDOW_DAYS=30

# Backend runtime config: Supabase metadata, not credentials.
# These are safe to know but are still synced with backend runtime config.
AVENTI_SUPABASE_URL=

# Backend secrets: required for deployed API/worker behavior.
AVENTI_DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54332/postgres
AVENTI_SUPABASE_SECRET_KEY=
AVENTI_INTERNAL_API_KEY=change-me
GOOGLE_API_KEY=
SERPAPI_API_KEY=
# Optional Pollinations.ai API key for higher image generation rate limits.
POLLINATIONS_API_KEY=

# Local-only AWS / SQS development config.
# For real AWS Lambda deploys, Terraform supplies SQS_WORKER_QUEUE_URL and IAM credentials.
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SQS_WORKER_QUEUE_URL=http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/aventi-dev-worker-jobs
