# Public browser config. These values are bundled into the Next.js client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_BASE_URL=

# Marketing / “Get App” — full store URLs (optional overrides).
# Android defaults to Play Store for package com.crestcode.aventi from apps/mobile/app.json.
NEXT_PUBLIC_PLAY_STORE_URL=
# iOS: set when the app is on the App Store, e.g. https://apps.apple.com/us/app/aventi/id1234567890
NEXT_PUBLIC_IOS_APP_STORE_URL=
