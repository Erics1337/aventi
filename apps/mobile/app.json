{
  "expo": {
    "name": "Aventi",
    "slug": "aventi",
    "scheme": "aventi",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Aventi uses your location to personalize local events and nightlife discovery."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aventi.app"
    },
    "android": {
      "package": "com.aventi.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0a7b66a7-c65c-4356-a5da-5eccde6e5000"
      }
    }
  }
}
