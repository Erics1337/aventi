{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": [
      "nativewind/types"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@aventi/contracts": [
        "../../packages/contracts/src/index.ts"
      ],
      "@aventi/design-tokens": [
        "../../packages/design-tokens/src/index.ts"
      ],
      "@aventi/api-client": [
        "../../packages/api-client/src/index.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
