{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@aventi/contracts": ["packages/contracts/src/index.ts"],
      "@aventi/design-tokens": ["packages/design-tokens/src/index.ts"],
      "@aventi/api-client": ["packages/api-client/src/index.ts"]
    }
  }
}
